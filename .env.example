# LLM Configuration
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=MiniMax-M2.5

# Embedding Configuration (REQUIRED for memU)
# memU requires a working embedding endpoint

# Option 1: Local LMStudio (fast, free, private)
EMBEDDING_API_KEY=123
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Option 2: OpenAI embeddings (most reliable)
# EMBEDDING_API_KEY=your_openai_api_key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# Database Configuration (for persistent storage)
# By default, uses in-memory storage (data lost on restart)

# Option 1: PostgreSQL (RECOMMENDED - persistent, production-ready)
# Run: ./configure_docker_mirror.sh && ./setup_postgres_simple.sh
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memu

# Option 2: memU Cloud (easiest - no database needed)
# Get API key at: https://memu.so
# MEMU_API_KEY=your_memu_api_key
# MEMU_ENDPOINT=https://api.memu.so

# Memory store path
MEMORY_STORE_PATH=./memory_store

# Agent Configuration
PROACTIVE_INTERVAL=60

# Runtime Configuration
MODE=local
VERBOSE=false
