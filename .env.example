# DashScope / OpenAI compatible LLM settings
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=kimi-k2.5

# Embedding model (optional - uses hash fallback if not configured)
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Memory store path (for local mode)
MEMORY_STORE_PATH=./memory_store

# Agent settings
PROACTIVE_INTERVAL=60

# Runtime settings
MODE=local
VERBOSE=false
